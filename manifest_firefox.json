{
  "manifest_version": 2,
  "name": "New Tab",
  "version": "1.1.0",
  "description": "A beautiful, private new tab experience with Quran verse, prayer times, habits and more.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "background": {
    "scripts": ["js/background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/content.js"],
      "run_at": "document_start"
    }
  ],
  "permissions": [
    "storage",
    "tabs",
    "bookmarks",
    "alarms",
    "geolocation",
    "https://api.alquran.cloud/*",
    "https://everyayah.com/*",
    "https://api.aladhan.com/*",
    "https://nominatim.openstreetmap.org/*",
    "https://api.unsplash.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "strict_min_version": "109.0"
    }
  }
}
