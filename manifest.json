{
  "manifest_version": 3,
  "name": "Noor Tab — Islamic New Tab",
  "version": "1.3.0",
  "description": "A beautiful Islamic new tab. Daily Quran verse with Alafasy audio, live prayer times for any city, 5-prayer Salah tracker with streaks, Dhikr reminders on all pages, habit tracker, favourite verses, quick notes, site usage stats, and stunning Unsplash backgrounds — all in a glassmorphism design with 5 themes.",
  "chrome_url_overrides": { "newtab": "newtab.html" },
  "background": { "service_worker": "js/background.js" },
  "content_scripts": [{ "matches": ["<all_urls>"], "js": ["js/content.js"], "run_at": "document_idle" }],
  "permissions": ["storage", "tabs", "bookmarks", "alarms", "geolocation", "scripting"],
  "host_permissions": [
    "https://api.alquran.cloud/*",
    "https://cdn.islamic.network/*",
    "https://everyayah.com/*",
    "https://verses.quran.com/*",
    "https://api.aladhan.com/*",
    "https://nominatim.openstreetmap.org/*",
    "https://api.unsplash.com/*",
    "https://www.google.com/s2/favicons*"
  ],
  "icons": { "16": "icons/icon16.png", "32": "icons/icon32.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "action": { "default_icon": { "16": "icons/icon16.png", "32": "icons/icon32.png", "48": "icons/icon48.png", "128": "icons/icon128.png" } }
}
