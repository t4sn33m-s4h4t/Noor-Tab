{
  "manifest_version": 3,
  "name": "Noor Tab — Islamic New Tab",
  "version": "2.0.0",
  "description": "Islamic new tab: daily Quran verse, prayer times, Salah & habit tracker, notes, browser lock.",
  "chrome_url_overrides": { "newtab": "newtab.html" },
  "background": { "service_worker": "js/background.js" },
  "permissions": [
    "storage",
    "tabs",
    "windows",
    "bookmarks",
    "alarms",
    "geolocation"
  ],
  "host_permissions": [
    "https://api.alquran.cloud/*",
    "https://cdn.islamic.network/*",
    "https://everyayah.com/*",
    "https://verses.quran.com/*",
    "https://api.aladhan.com/*",
    "https://nominatim.openstreetmap.org/*",
    "https://api.unsplash.com/*",
    "https://www.google.com/s2/favicons*",
    "https://duckduckgo.com/*"
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "pages/popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["pages/*.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
